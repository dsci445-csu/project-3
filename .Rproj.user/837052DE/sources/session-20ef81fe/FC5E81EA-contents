    c. Perform boosting on the training set with $1,000$ trees for a range of values of the shrinkage parameter $\lambda$. Produce a plot with different shrinkage values on the $x$-axis and the corresponing training MSE on the $y$-axis.
    
    ```{r}
    
    shrinkage_values <- c(0.001, 0.01, 0.05, 0.1, 0.2)
    
    train_mse <- c()
    test_mse <- c()
    
    for(lambda in shrinkage_values) {
      boost_model <- gbm(Salary ~ ., data = train_data, distribution = "gaussian", n.trees = 1000, shrinkage = lambda, interaction.depth = 4)
      
      train_pred <- predict(boost_model, train_data, n.trees = 1000)
      train_mse <- c(train_mse, mean((train_data$Salary - train_pred)^2))
      
      test_pred <- predict(boost_model, test_data, n.trees = 1000)
      test_mse <- c(test_mse, mean((test_data$Salary - test_pred)^2))
    }
    
    plot(shrinkage_values, train_mse, type = "b", xlab = "Shrinkage", ylab = "Training MSE", main = "Training MSE vs. Shrinkage")
    
    ```
    
