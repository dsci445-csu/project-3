```{r}

# Step 1): Creating aggregate training set

final_train <- train %>%
  left_join(stores, by = "store_nbr") %>%
  left_join(oil, by = "date") %>%
  left_join(transactions, by = c("date", "store_nbr"))

# want a unique type variable for holiday types
holidays_events <- holidays_events %>%
  rename(holiday_type = type)

final_train$nation <- "Ecuador"

```

```{r}

holidays_events_clean <- holidays_events %>%
  mutate(
    national_holiday = if_else(locale == "National", 1, 0),
    state_holiday = if_else(locale == "Regional", 1, 0),
    city_holiday = if_else(locale == "Local", 1, 0),
    state = if_else(locale == "Regional", locale_name, NA_character_),
    city = if_else(locale == "Local", locale_name, NA_character_),
    nation = if_else(locale == "National", locale_name, NA_character_)
  ) %>%
  select(date, city, state, nation, city_holiday, state_holiday, national_holiday, locale, holiday_type, transferred)

# Step 2: Perform a single join to merge all holiday information
final_train <- final_train %>%
  left_join(
    holidays_events_clean %>% select(date, nation, national_holiday, transferred, holiday_type, locale),  # Only join on date and national_holiday
    by = c("date","nation")
  ) %>% distinct()

# Merge state holidays by date and state (if state exists in final_train)
final_train <- final_train %>%
  left_join(
    holidays_events_clean %>% select(date, state, state_holiday),  # Only join on date and state
    by = c("date", "state")
  ) %>% distinct()

# Merge city holidays by date and city (if city exists in final_train)
final_train <- final_train %>%
  left_join(
    holidays_events_clean %>% select(date, city, city_holiday),  # Only join on date and city
    by = c("date", "city")
  ) %>% distinct()

```

