```{r, output = FALSE}
library(ggplot2)
library(dplyr)
library(tidyr)
library(lubridate)
library(forecast)
```

```{r}
train <- read.csv("../Data/train.csv")
oil <- read.csv("../Data/oil.csv")
```

```{r}

sales_by_year <- train %>%
  mutate(date = as.Date(date)) %>%
  group_by(date) %>%
  summarise(total_sales = sum(sales)) %>%
  mutate(year = format(date, "%Y"))
  
ggplot(sales_by_year, aes(x = date, y = total_sales, color = year)) +
  geom_line() +
  labs(
    title = "Store Sales Over Time By Year",
    x = "Date",
    y = "Total Sales",
    color = "Year"
  ) +
  theme_minimal()
```

Can see a consistent upward trend in total sales by year. 

```{r, warning=FALSE}

train <- train %>%
  mutate(date = as.Date(date))

oil <- oil %>%
  mutate(date = as.Date(date))

sales_oil_data <- train %>%
  group_by(date) %>%
  summarise(total_sales = sum(sales)) %>%
  left_join(oil, by = "date") %>%
  rename(oil_price = dcoilwtico)
  
ggplot(sales_oil_data, aes(x = date)) +
  geom_line(aes(y = total_sales, color = "Sales")) +
  geom_line(aes(y = oil_price * 1000, color = "Oil Price (Scaled")) +
  scale_y_continuous(
    name = "Total Sales",
    sec.axis = sec_axis(~ . / 1000, name = "Oil Price")
  ) +
  scale_color_manual(
    name = "Legend",
    values = c("Sales" = "blue", "Oil Price (Scaled)" = "red")
  ) +
  labs(
    title = "Store Sales OVer Time with Oil Price Overlay",
    x = "Date"
  ) +
  theme_minimal()
```
Can see that higher oil prices in earlier years could have resulted in lower total sales because of factors such as transportation costs reducing overhead, and increased consumer spending because of higher disposable income values in the country.

```{r}
test <- read.csv("../Data/test.csv")

train <- train %>% mutate(date = as.Date(date))
test <- test %>% mutate(date = as.Date(date))

time_series_data <- train %>%
  group_by(date) %>%
  summarise(total_sales = sum(sales))

```

```{r}

ts_data <- ts(time_series_data$total_sales,
              frequency = 365,
              start = c(year(min(time_series_data$date)), yday(min(time_series_data$date)))
)

arima_model <- auto.arima(ts_data, seasonal = TRUE)
summary(arima_model)
```

```{r}

forecast_horizon <- nrow(test)
arima_forecast <- forecast(arima_model, h = forecast_horizon)
head(arima_forecast$mean)

```
```{r}

submission <- data.frame(
  id = test$id,
  sales = as.numeric(arima_forecast$mean)
)

write.csv(submission, "submission.csv", row.names = FALSE)


checkresiduals(arima_model)
```

