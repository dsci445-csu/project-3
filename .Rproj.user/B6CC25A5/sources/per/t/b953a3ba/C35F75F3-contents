```{r}
library(dplyr)
library(lubridate)

# data merging

holidays_events <- holidays_events %>%
  mutate(
    state = case_when(
      locale == "Regional" ~ locale_name,  # Keep `locale` as is for Regional and rename to `state`
      TRUE ~ NA_character_            # Set to NA for other rows
    ),
    city = case_when(
      locale == "Local" ~ locale_name,     # Keep `locale` as is for Local and rename to `city`
      TRUE ~ NA_character_            # Set to NA for other rows
    )
  )

# Step 2: Split the holidays data based on locale type
national_holidays <- holidays_events %>%
  filter(locale == "National")

regional_holidays <- holidays_events %>%
  filter(locale == "Regional")

local_holidays <- holidays_events %>%
  filter(locale == "Local")

# Step 3: Merge with the train dataset using the appropriate columns
# National holidays only on `date`
train <- train %>%
  left_join(national_holidays, by = "date")

# Regional holidays on `date` and `state`
train <- train %>%
  left_join(regional_holidays, by = c("date", "state"))

# Local holidays on `date` and `city`
train <- train %>%
  left_join(local_holidays, by = c("date", "city"))

final_train <- train %>%
  left_join(stores, by = "store_nbr") %>%
  left_join(oil, by = "date") %>%
  left_join(transactions, by = c("date", "store_nbr"))

```

